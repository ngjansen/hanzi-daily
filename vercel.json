{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "hanzidaily.com" }],
      "destination": "https://www.hanzidaily.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/og-image.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/send-daily", "schedule": "0 0 * * *" }
  ]
}
